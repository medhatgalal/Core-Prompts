  "shared_summary": "Architecture Studio for API design, database design, design-pattern selection, and system design with black-box boundaries, concrete artifacts, and migration-safe recommendations.",
  "shared_constraints": [
    "Publish architecture guidance only; do not orchestrate or delegate work.",
    "Use deterministic, sectioned outputs with explicit scorecards.",
    "Prefer replaceable interfaces and stable boundaries over implementation-heavy advice.",
    "Make assumptions, trade-offs, evidence, and rollback explicit.",
    "Validate and report migration impact when designs change interfaces or ownership."
  ],
  "modes": [
    {
      "mode_slug": "design-api",
      "display_name": "Design API",
      "source_refs": [
        "https://github.com/harish-garg/gemini-cli-prompt-library/blob/main/commands/architecture/design-api.toml"
      ],
      "mode_summary": "Design resource-oriented APIs with explicit resource models, endpoint contracts, validation, security, and error behavior.",
      "required_inputs": [
        "product requirements",
        "resource model",
        "auth or policy constraints"
      ],
      "expected_outputs": [
        "endpoint contract map",
        "request/response contract",
        "error model",
        "trade-off assessment",
        "rejected alternative",
        "migration and rollback guidance",
        "quality scorecard",
        "validation plan"
      ],
      "examples": [
        "RESTful CRUD service",
        "internal service boundary"
      ],
      "uplift_notes": [
        "Prefer nouns and stable resource boundaries.",
        "Keep auth, pagination, and versioning explicit.",
        "Include at least one explicit rollback path for API changes."
      ]
    },
    {
      "mode_slug": "design-database",
      "display_name": "Design Database",
      "source_refs": [
        "https://github.com/harish-garg/gemini-cli-prompt-library/blob/main/commands/architecture/design-database.toml"
      ],
      "mode_summary": "Design schemas and storage structures that match access patterns, consistency goals, and evolution needs.",
      "required_inputs": [
        "entity list",
        "access patterns",
        "integrity requirements"
      ],
      "expected_outputs": [
        "schema outline",
        "index strategy",
        "normalization notes",
        "consistency trade-off",
        "migration and rollback guidance",
        "quality scorecard"
      ],
      "examples": [
        "OLTP schema",
        "event-driven analytics subsystem"
      ],
      "uplift_notes": [
        "Call out intentional denormalization and failure impact.",
        "Tie indexes to actual query paths.",
        "Include consistency-vs-availability trade-off and rollback checkpoint."
      ]
    },
    {
      "mode_slug": "design-patterns",
      "display_name": "Design Patterns",
      "source_refs": [
        "https://github.com/harish-garg/gemini-cli-prompt-library/blob/main/commands/architecture/design-patterns.toml",
        "https://raw.githubusercontent.com/Alexanderdunlop/ai-architecture-prompts/main/prompts/claude-prompt.md"
      ],
      "mode_summary": "Choose structural patterns that reduce coupling and improve replaceability under changing requirements.",
      "required_inputs": [
        "current design problem",
        "extensibility goals",
        "change history",
        "risk boundaries"
      ],
      "expected_outputs": [
        "pattern candidate list",
        "before/after boundary sketch",
        "rejected alternatives",
        "risk assessment",
        "quality scorecard",
        "replacement and rollback strategy"
      ],
      "examples": [
        "Factory vs builder",
        "adapter for legacy integration"
      ],
      "uplift_notes": [
        "Explain trade-offs and why each fit is chosen.",
        "Avoid pattern cargo-culting; always include replacement implications.",
        "Include rollback plan for each non-backward-compatible boundary change."
      ]
    },
    {
      "mode_slug": "system-design",
      "display_name": "System Design",
      "source_refs": [
        "https://github.com/harish-garg/gemini-cli-prompt-library/blob/main/commands/architecture/system-design.toml",
