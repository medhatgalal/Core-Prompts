      "expected_outputs": [
        "requirements-to-architecture mapping",
        "component model",
        "data flow",
        "failure model",
        "deployment and rollback plan",
        "dependency ownership map",
        "quality scorecard"
      ],
      "examples": [
        "SaaS control plane",
        "event-driven pipeline"
      ],
      "uplift_notes": [
        "Keep modules replaceable where possible.",
        "Separate policy from mechanism in each subsystem."
      ]
    }
