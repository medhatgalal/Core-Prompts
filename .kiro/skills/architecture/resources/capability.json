      ],
      "mode_summary": "Design resource-oriented APIs with clear endpoint semantics, validation, and versioning.",
      "required_inputs": [
        "product requirements",
        "resource model",
        "auth or policy constraints"
      ],
      "expected_outputs": [
        "endpoint map",
        "request/response contract",
        "error model",
        "trade-offs"
      ],
      "examples": [
        "RESTful CRUD service",
        "internal service boundary"
      ],
      "uplift_notes": [
        "Prefer nouns and stable resource boundaries.",
        "Keep auth, pagination, and versioning explicit."
      ]
    },
    {
      "mode_slug": "design-database",
      "display_name": "Design Database",
      "source_refs": [
        "https://github.com/harish-garg/gemini-cli-prompt-library/blob/main/commands/architecture/design-database.toml"
      ],
      "mode_summary": "Design schemas and storage structures that match access patterns and evolution needs.",
      "required_inputs": [
        "entity list",
        "access patterns",
        "integrity requirements"
      ],
      "expected_outputs": [
        "schema outline",
        "key/index plan",
        "normalization notes",
        "migration guidance"
      ],
      "examples": [
        "OLTP schema",
        "event or document-backed subsystem"
      ],
      "uplift_notes": [
        "Call out where denormalization is intentional.",
        "Tie indexes to real query paths."
      ]
    },
    {
