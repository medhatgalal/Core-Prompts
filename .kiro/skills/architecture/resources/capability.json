      "expected_outputs": [
        "pattern recommendation",
        "before/after sketch",
        "anti-pattern warnings"
      ],
      "examples": [
        "Factory vs builder",
        "adapter for legacy integration"
      ],
      "uplift_notes": [
        "Explain the forces, not just the pattern name.",
        "Avoid pattern cargo culting."
      ]
    },
